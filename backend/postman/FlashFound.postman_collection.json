{
  "info": {
    "_postman_id": "2c2308f0-9f75-4fe8-a06f-4a4fc8f3ad34",
    "name": "FlashFound API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        },
        {
          "name": "GET /api/v1/health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/health"
          }
        }
      ]
    },
    {
      "name": "Profile",
      "item": [
        {
          "name": "POST /api/v1/profile/bootstrap",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/profile/bootstrap"
          }
        },
        {
          "name": "GET /api/v1/profile/onboarding-status",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/profile/onboarding-status"
          }
        }
      ]
    },
    {
      "name": "Organiser Access",
      "item": [
        {
          "name": "POST /api/v1/organiser-access/request",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/organiser-access/request"
          }
        },
        {
          "name": "POST /api/v1/admin/auth",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"access_key\":\"{{adminAccessKey}}\"}"
            },
            "url": "{{baseUrl}}/api/v1/admin/auth"
          }
        },
        {
          "name": "GET /api/v1/admin/organiser-requests",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/admin/organiser-requests?status=pending"
          }
        }
      ]
    },
    {
      "name": "Private Access + Notifications",
      "item": [
        {
          "name": "POST /api/v1/private-access/requests",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{requesterToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"event_id\":\"{{eventId}}\",\"target_user_id\":\"{{targetUserId}}\"}"
            },
            "url": "{{baseUrl}}/api/v1/private-access/requests"
          }
        },
        {
          "name": "GET /api/v1/notifications",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{targetToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/notifications"
          }
        },
        {
          "name": "POST /api/v1/private-access/requests/:id/approve",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{targetToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/private-access/requests/{{privateRequestId}}/approve"
          }
        },
        {
          "name": "POST /api/v1/notifications/read-all",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{targetToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/notifications/read-all"
          }
        }
      ]
    }
  ]
}
